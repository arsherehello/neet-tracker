<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_total_big"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#0B2A2E"
        android:text="0.0h" />

    <TextView
        android:id="@+id/widget_total_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#6B8489"
        android:paddingBottom="10dp"
        android:text="logged today" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <ImageView
                android:id="@+id/widget_pie_physics"
                android:layout_width="46dp"
                android:layout_height="46dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phy"
                android:textSize="10sp"
                android:textColor="#6B8489"
                android:paddingTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <ImageView
                android:id="@+id/widget_pie_chemistry"
                android:layout_width="46dp"
                android:layout_height="46dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chem"
                android:textSize="10sp"
                android:textColor="#6B8489"
                android:paddingTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <ImageView
                android:id="@+id/widget_pie_biology"
                android:layout_width="46dp"
                android:layout_height="46dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bio"
                android:textSize="10sp"
                android:textColor="#6B8489"
                android:paddingTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Today's activity"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#0B2A2E"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/widget_bar_physics_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="9sp"
        android:textColor="#6B8489"
        android:text="Physics 0.0h" />
    <ProgressBar
        android:id="@+id/widget_bar_physics"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/widget_bar_chemistry_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="9sp"
        android:textColor="#6B8489"
        android:paddingTop="4dp"
        android:text="Chemistry 0.0h" />
    <ProgressBar
        android:id="@+id/widget_bar_chemistry"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/widget_bar_biology_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="9sp"
        android:textColor="#6B8489"
        android:paddingTop="4dp"
        android:text="Biology 0.0h" />
    <ProgressBar
        android:id="@+id/widget_bar_biology"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/widget_bar_sleep_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="9sp"
        android:textColor="#6B8489"
        android:paddingTop="4dp"
        android:text="Sleep 0.0h" />
    <ProgressBar
        android:id="@+id/widget_bar_sleep"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/widget_bar_chores_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="9sp"
        android:textColor="#6B8489"
        android:paddingTop="4dp"
        android:text="Chores 0.0h" />
    <ProgressBar
        android:id="@+id/widget_bar_chores"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:max="100"
        android:progress="0" />

</LinearLayout>
