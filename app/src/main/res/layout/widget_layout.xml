<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_today_hours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#0B2A2E"
        android:paddingBottom="8dp"
        android:text="0.0h logged today" />

    <TextView
        android:id="@+id/widget_physics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#0E7C7B"
        android:text="Physics 0%" />
    <ProgressBar
        android:id="@+id/widget_physics_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/widget_chemistry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#2FAF7A"
        android:paddingTop="6dp"
        android:text="Chemistry 0%" />
    <ProgressBar
        android:id="@+id/widget_chemistry_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/widget_biology"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#FF6A55"
        android:paddingTop="6dp"
        android:text="Biology 0%" />
    <ProgressBar
        android:id="@+id/widget_biology_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="100"
        android:progress="0" />

</LinearLayout>
